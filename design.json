{
  "design_system": {
    "theme": "light",
    "typography": {
      "fonts": {
        "headings": "'Montserrat', sans-serif",
        "body": "'Inter', sans-serif"
      },
      "weights": {
        "regular": 400,
        "medium": 500,
        "semibold": 600,
        "bold": 700
      }
    },
    "colors": {
      "background": {
        "main": "#F8FAFC",
        "card": "#FFFFFF",
        "highlight": "#F0F4FF"
      },
      "text": {
        "primary": "#0F172A",
        "secondary": "#64748B",
        "price": "#1E3A8A"
      },
      "accent": {
        "primary": "#4F46E5",
        "primary_hover": "#4338CA",
        "icon": "#818CF8",
        "border": "#E2E8F0"
      }
    },
    "components": {
      "cards": {
        "border_radius": "16px",
        "padding": "16px",
        "shadow_default": "0 1px 3px rgba(0,0,0,0.05)",
        "shadow_hover": "0 10px 15px -3px rgba(0,0,0,0.1)",
        "border": "1px solid #F1F5F9"
      },
      "images": {
        "border_radius": "12px",
        "aspect_ratio": "16/9"
      },
      "buttons": {
        "border_radius": "8px",
        "primary_bg": "#4F46E5",
        "primary_text": "#FFFFFF"
      }
    },
    "layout": {
      "max_width": "1200px",
      "grid_gap": "24px"
    }
  }
}
